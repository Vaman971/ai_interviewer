# ===========================================
# AI Interviewer Platform - Environment Config
# ===========================================

# Application
APP_NAME=ai-interviewer
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database (SQLite for local dev, Postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./ai_interviewer.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_interviewer

# Redis (optional for local dev)
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Speech Services (optional)
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Avatar Services (optional)
DID_API_KEY=your-did-api-key

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
